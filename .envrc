# NixOS: cadquery-ocp wheels need native libraries via LD_LIBRARY_PATH.
# Resolves Nix store paths dynamically so they survive garbage collection updates.
if [[ "$(uname)" == "Linux" ]] && command -v nix >/dev/null 2>&1; then
  nix_lib() { nix eval --raw "nixpkgs#$1" 2>/dev/null; }
  export LD_LIBRARY_PATH="$(nix_lib stdenv.cc.cc.lib)/lib:$(nix_lib libGL)/lib:$(nix_lib libx11)/lib:$(nix_lib expat)/lib:$(nix_lib zlib)/lib"
fi
